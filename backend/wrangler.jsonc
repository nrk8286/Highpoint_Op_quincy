{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "highpoints-backend-v2",
  "main": "src/index.js",
  "compatibility_date": "2026-05-23",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  },
  "vars": {
    "APP_ORIGIN": "https://highpoints.work",
    "SECURITY_CAMERA_URL": "https://cameras.highpoints.work",
    "OUTLOOK_CLIENT_ID": "e1fe6dd8-ba31-4d61-89e7-88639da4683d",
    "OUTLOOK_REDIRECT_URI": "https://highpoints.work/app",
    "OUTLOOK_SCOPES": "openid profile offline_access User.Read Mail.Read Mail.Send Calendars.ReadWrite",
    "DOCUMENT_AI_ENDPOINT": "",
    "DOCUMENT_AI_MODEL": "",
    "NEO4J_QUERY_ENDPOINT": "http://127.0.0.1:7474/db/neo4j/tx/commit",
    "NEO4J_DATABASE": "neo4j",
    "AZURE_SUBSCRIPTION_NAME": "Azure subscription 1",
    "AZURE_RESOURCE_GROUP": "Highpoint",
    "AZURE_VMSS_RESOURCE_GROUP": "vmss-rg",
    "AZURE_ORIGIN_URL": "https://server.highpoints.work",
    "AZURE_STATUS_ENDPOINT": "https://server.highpoints.work/azure/status",
    "AZURE_APP_ENDPOINT": "https://server.highpoints.work/app"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "highpoints",
      "database_id": "dfa0fa9a-2f15-47c7-a286-8a93634ed2df",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "DOCUMENTS",
      "bucket_name": "highpoints-documents"
    }
  ],
  "routes": [
    {
      "pattern": "highpoints.work/",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/robots.txt",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/sitemap.xml",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/.well-known/*",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/healthz",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/api/*",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/app",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/app/*",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/app*",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/app.bundle.js",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/vendor/*",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/signup",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/features",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/privacy",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/support",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/operations-status",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/search",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/pricing",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/executive-command-center",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/ai-operations",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/workflow-automation",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/readiness-assessment",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/azure-services",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/integrations",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/senior-living-operations",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/facility-maintenance-software",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/survey-readiness",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/housekeeping-management",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/sw.js",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/manifest.json",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    },
    {
      "pattern": "highpoints.work/icons/*",
      "zone_id": "0f5ea8d9b668cc5c7a029e635d46fcc9"
    }
  ]
}
