{
  "name": "highpoints-mobile",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Native store packaging for High Point Ops.",
  "scripts": {
    "sync": "capacitor sync",
    "sync:android": "capacitor sync android",
    "sync:ios": "capacitor sync ios",
    "open:android": "capacitor open android",
    "open:ios": "capacitor open ios",
    "build:android": "cd android && ./gradlew bundleRelease",
    "build:android:apk": "cd android && ./gradlew assembleRelease",
    "build:android:debug": "cd android && ./gradlew assembleDebug",
    "doctor": "capacitor doctor",
    "lint": "npm run validate:backend && npm run validate:shell && npm run validate:go-site",
    "typecheck": "npm run validate:backend",
    "test": "npm run validate:go-site",
    "build": "npm run validate:shell && npm run validate:backend && npm run validate:go-site",
    "validate:shell": "node scripts/validate-shell.mjs",
    "validate:backend": "node scripts/validate-backend.mjs",
    "graph:migrate": "node backend/scripts/apply-graph-migrations.mjs",
    "graph:check": "node backend/scripts/check-graph.mjs",
    "site:go": "go run ./site-go",
    "site:go:export": "go run ./site-go -export www/go-site",
    "validate:go-site": "go test ./site-go"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "typescript": "^6.0.3"
  }
}
